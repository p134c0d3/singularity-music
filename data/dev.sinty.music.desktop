[Desktop Entry]
Name=Music
Comment=Play music and audio files
Exec=singularity-music %f
Icon=dev.sinty.music
Terminal=false
Type=Application
Categories=AudioVideo;Audio;Player;
MimeType=audio/mpeg;audio/flac;audio/ogg;audio/wav;audio/aac;audio/x-vorbis+ogg;audio/x-flac;audio/mp4;audio/x-m4a;audio/opus;audio/webm;
StartupNotify=true
StartupWMClass=dev.sinty.music
